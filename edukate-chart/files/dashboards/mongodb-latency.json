{
  "title": "Edukate — MongoDB Latency",
  "uid": "edukate-mongodb-latency",
  "description": "Per-command latency, throughput, and error rate for MongoDB operations across all Edukate services",
  "tags": ["edukate", "mongodb"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "graphTooltip": 1,
  "editable": true,
  "fiscalYearStartMonth": 0,
  "links": [],
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": []
      },
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(mongodb_driver_commands_seconds_count, application)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "sort": 1,
        "hide": 0,
        "options": []
      },
      {
        "name": "command",
        "type": "query",
        "label": "Command",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(mongodb_driver_commands_seconds_count{application=~\"$service\"}, command)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "sort": 1,
        "hide": 0,
        "options": []
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Command Rate",
      "id": 2,
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(mongodb_driver_commands_seconds_count{application=~\"$service\", command=~\"$command\", status=\"SUCCEEDED\"}[1m]))",
          "legendFormat": "cmds/s"
        }
      ]
    },
    {
      "type": "stat",
      "title": "p99 Latency",
      "id": 3,
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(mongodb_driver_commands_seconds_bucket{application=~\"$service\", command=~\"$command\"}[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Failed Commands",
      "id": 4,
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.001 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(mongodb_driver_commands_seconds_count{application=~\"$service\", command=~\"$command\", status=\"FAILED\"}[1m]))",
          "legendFormat": "failures/s"
        }
      ]
    },
    {
      "type": "row",
      "title": "Latency by Command",
      "id": 10,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "p95 Latency per Command",
      "id": 5,
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 8 },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (command, le) (rate(mongodb_driver_commands_seconds_bucket{application=~\"$service\", command=~\"$command\"}[5m])))",
          "legendFormat": "{{command}} p95"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p99 Latency per Command",
      "id": 6,
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 8 },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (command, le) (rate(mongodb_driver_commands_seconds_bucket{application=~\"$service\", command=~\"$command\"}[5m])))",
          "legendFormat": "{{command}} p99"
        }
      ]
    },
    {
      "type": "row",
      "title": "Throughput & Errors",
      "id": 11,
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Command Rate per Type",
      "id": 7,
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (command) (rate(mongodb_driver_commands_seconds_count{application=~\"$service\", command=~\"$command\", status=\"SUCCEEDED\"}[1m]))",
          "legendFormat": "{{command}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Failed Commands per Type",
      "id": 8,
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (command) (rate(mongodb_driver_commands_seconds_count{application=~\"$service\", command=~\"$command\", status=\"FAILED\"}[1m]))",
          "legendFormat": "{{command}}"
        }
      ]
    },
    {
      "type": "table",
      "title": "Slowest Commands (p99, last 5 min)",
      "id": 9,
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "application" }, "properties": [{ "id": "custom.width", "value": 160 }] },
          { "matcher": { "id": "byName", "options": "command" }, "properties": [{ "id": "custom.width", "value": 160 }] },
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "p99 latency" }, { "id": "custom.width", "value": 120 }] }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "p99 latency", "desc": true }],
        "footer": { "show": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "topk(20, histogram_quantile(0.99, sum by (application, command, le) (rate(mongodb_driver_commands_seconds_bucket{application=~\"$service\", command=~\"$command\"}[5m]))))",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "le": true, "job": true, "instance": true } } }
      ]
    }
  ]
}
